{
  "extends": "stylelint-config-standard",
  "rules": {
    "at-rule-no-unknown": [
      true,
      {
        "ignoreAtRules": ["theme", "apply", "tailwind", "layer", "plugin", "config", "utility", "variant", "custom-variant", "source"]
      }
    ],
    "declaration-block-no-duplicate-custom-properties": true,
    "import-notation": "string"
  }
}
