# Search-engine ownership verification tokens (optional, non-secret).
# See the "Search-engine verification" section of README.md.

# Google Search Console -> add property -> "HTML tag" method
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Bing Webmaster Tools -> add site -> "Meta tag" method
NEXT_PUBLIC_BING_SITE_VERIFICATION=

# Cloudflare Web Analytics beacon token (optional, non-secret). Cookieless,
# no PII, no consent banner required. See the "Analytics" section of
# README.md. Cloudflare dashboard -> Web Analytics -> add a site -> copy the
# "token" value out of the generated <script> snippet.
NEXT_PUBLIC_CF_BEACON_TOKEN=
