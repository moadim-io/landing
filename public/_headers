# Cloudflare Pages Cache-Control policy for the static export.
# https://developers.cloudflare.com/pages/configuration/headers/
#
# Without this file the site relies on the host's default caching, which both
# re-fetches content-hashed immutable assets and risks serving stale HTML.
#
# Cloudflare applies *every* matching rule and joins a repeated header with a
# comma, so two rules that both match a path and both set Cache-Control would
# emit one conflicting value. Rules are processed top-to-bottom, and a later,
# more specific rule can detach an inherited header with `! <Header>`. So the
# broad revalidate rule comes first, and each more specific rule below detaches
# that inherited Cache-Control before setting its own — leaving each path with
# a single, unambiguous value instead of several comma-joined ones.

# HTML and everything else: cache but always revalidate, so a redeploy is
# picked up immediately instead of serving a stale page.
/*
  Cache-Control: public, max-age=0, must-revalidate

# Next.js emits content-hashed, immutable assets (JS, CSS, fonts, media) under
# /_next/static/*. A new build changes the hash (and the URL), so these can be
# cached forever. Detach the inherited revalidate value from the rule above so
# this path is served with the immutable directive only.
/_next/static/*
  ! Cache-Control
  Cache-Control: public, max-age=31536000, immutable

# Generated metadata assets whose referencing URL carries a content hash:
# the OG/Twitter share images (`/opengraph-image?<hash>`, `/twitter-image?<hash>`)
# and the favicon (`/icon?<hash>`, generated from `app/icon.tsx`). Because the
# URL changes whenever the bytes change, the bytes at any given URL are
# immutable — so an unfurl bot or crawler can cache them forever instead of
# re-fetching from the origin on every request. Without this they fall under
# the broad `max-age=0` rule above.
/opengraph-image
  ! Cache-Control
  Cache-Control: public, max-age=31536000, immutable
/twitter-image
  ! Cache-Control
  Cache-Control: public, max-age=31536000, immutable
/icon
  ! Cache-Control
  Cache-Control: public, max-age=31536000, immutable

# Crawler-fetched metadata served from a stable, unhashed URL: robots.txt and
# the sitemap. These can change on a redeploy, so they can't be immutable — but
# a one-day cache still spares the origin a re-fetch on every crawl while letting
# a redeploy propagate within 24h.
/robots.txt
  ! Cache-Control
  Cache-Control: public, max-age=86400
/sitemap.xml
  ! Cache-Control
  Cache-Control: public, max-age=86400
