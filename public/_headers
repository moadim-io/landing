# Cloudflare Pages Cache-Control policy for the static export.
# https://developers.cloudflare.com/pages/configuration/headers/
#
# Without this file the site relies on the host's default caching, which both
# re-fetches content-hashed immutable assets and risks serving stale HTML.

# Next.js emits content-hashed, immutable assets (JS, CSS, fonts, media) under
# /_next/static/*. A new build changes the hash (and the URL), so these can be
# cached forever.
/_next/static/*
  Cache-Control: public, max-age=31536000, immutable

# HTML and everything else: cache but always revalidate, so a redeploy is
# picked up immediately instead of serving a stale page.
/*
  Cache-Control: public, max-age=0, must-revalidate

# Baseline security response headers for every route. Cloudflare Pages applies
# all matching rule blocks, so these compose with the Cache-Control rules above.
# Kept to standard, behaviour-safe hardening for a static marketing site (no CSP,
# which would need per-asset tuning against Next.js's inline runtime).
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: DENY
  Permissions-Policy: camera=(), microphone=(), geolocation=(), interest-cohort=()
