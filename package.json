{
  "name": "landing",
  "version": "0.1.0",
  "private": true,
  "description": "The marketing/landing site for Moadim, an open-source loop engine for AI agents.",
  "license": "MIT",
  "author": "Moadim",
  "homepage": "https://moadim.io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/moadim-io/landing.git"
  },
  "bugs": {
    "url": "https://github.com/moadim-io/landing/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build && node scripts/inject-csp-hashes.mjs",
    "start": "npx serve out",
    "lint": "eslint",
    "lint:css": "stylelint \"app/**/*.css\"",
    "lint:md": "markdownlint-cli2",
    "lint:html": "html-validate 'out/**/*.html'",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:visual": "playwright test",
    "verify:export": "node scripts/verify-export.mjs"
  },
  "dependencies": {
    "next": "16.2.10",
    "react": "19.2.8",
    "react-dom": "19.2.8"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@next/eslint-plugin-next": "^16.2.10",
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9",
    "eslint-config-agent": "^3.1.0",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "html-validate": "^11.5.6",
    "jsdom": "^29.1.1",
    "markdownlint-cli2": "^0.23.0",
    "stylelint": "^17.14.1",
    "stylelint-config-standard": "^40.0.0",
    "tailwindcss": "^4",
    "typescript": "^6",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "postcss": "^8.5.10",
    "sharp": "^0.35.3"
  }
}
